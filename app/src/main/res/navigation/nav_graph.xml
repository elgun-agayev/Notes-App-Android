<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.notesapp.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_homeFragment_to_addEditFragment"
            app:destination="@id/addEditFragment"/>

            <action
                android:id="@+id/action_homeFragment_to_noteDetailFragment"
                app:destination="@id/noteDetailFragment"
            />

    </fragment>
    <fragment
        android:id="@+id/addEditFragment"
        android:name="com.example.notesapp.AddEditFragment"
        android:label="fragment_add_edit"
        tools:layout="@layout/fragment_add_edit" />
    <fragment
        android:id="@+id/noteDetailFragment"
        android:name="com.example.notesapp.NoteDetailFragment"
        android:label="fragment_note_detail"
        tools:layout="@layout/fragment_note_detail" >

        <argument
            android:name="noteId"
            app:argType="long"/>
    </fragment>


</navigation>