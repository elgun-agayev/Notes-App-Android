<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/rounded_screen_shape"
    tools:context=".AddEditFragment">


    <ImageButton
        android:id="@+id/ibtarrow"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="23dp"
        android:layout_marginTop="53dp"
        android:background="@drawable/search_shape"
        android:src="@drawable/arrow_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/view"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="196dp"
        android:background="@drawable/search_shape"
        app:layout_constraintStart_toEndOf="@+id/ibtarrow"
        app:layout_constraintTop_toTopOf="@+id/ibtarrow" />

    <ImageButton
        android:id="@+id/addeye"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@color/mid_gray"
        android:src="@drawable/visibility"
        app:layout_constraintBottom_toBottomOf="@+id/view"
        app:layout_constraintEnd_toEndOf="@+id/view"
        app:layout_constraintStart_toStartOf="@+id/view"
        app:layout_constraintTop_toTopOf="@+id/view" />

    <View
        android:id="@+id/view2"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="21dp"
        android:background="@drawable/search_shape"
        app:layout_constraintStart_toEndOf="@+id/view"
        app:layout_constraintTop_toTopOf="@+id/ibtarrow" />

    <ImageButton
        android:id="@+id/addSave"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@color/mid_gray"
        android:src="@drawable/save"
        app:layout_constraintBottom_toBottomOf="@+id/view2"
        app:layout_constraintEnd_toEndOf="@+id/view2"
        app:layout_constraintStart_toStartOf="@+id/view2"
        app:layout_constraintTop_toTopOf="@+id/view2" />

    <EditText
        android:id="@+id/etTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginHorizontal="24dp"
        android:backgroundTint="@color/dark_gray"
        android:fontFamily="@font/nunito"
        android:hint="Title"
        android:inputType="textCapSentences"
        android:paddingHorizontal="15dp"
        android:textColor="@color/white"
        android:textColorHint="@color/medium_gray"
        android:textSize="28sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ibtarrow" />

    <EditText
        android:id="@+id/etTypesomething"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginVertical="24dp"
        android:backgroundTint="@color/dark_gray"
        android:fontFamily="@font/nunito"
        android:gravity="top|start"
        android:hint="Type something..."
        android:inputType="textMultiLine"
        android:minLines="8"
        android:overScrollMode="always"
        android:padding="16dp"
        android:textColor="@color/white"
        android:textColorHint="@color/medium_gray"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/etTitle"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/etTitle"
        app:layout_constraintTop_toBottomOf="@+id/etTitle"
        app:layout_constraintVertical_bias="0.404" />

</androidx.constraintlayout.widget.ConstraintLayout>